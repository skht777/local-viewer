{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxlint-config-schema/refs/heads/main/schema.json",
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**"],
  "plugins": ["react", "typescript", "import", "unicorn", "promise", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "pedantic": "warn",
    "style": "warn",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "no-debugger": "error",
    "no-alert": "error",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-await-in-loop": "off",
    "no-var": "error",
    "prefer-const": "error",
    "react/jsx-no-target-blank": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "warn",
    "typescript/consistent-type-imports": "warn",

    "react/react-in-jsx-scope": "off",
    "react/jsx-max-depth": "off",
    "react/jsx-handler-names": "off",
    "react/jsx-props-no-spreading": "off",
    "react/jsx-boolean-value": "off",

    "import/no-named-export": "off",
    "import/no-default-export": "off",
    "import/prefer-default-export": "off",
    "import/group-exports": "off",
    "import/exports-last": "off",
    "import/max-dependencies": "off",
    "import/no-namespace": "off",
    "import/no-unassigned-import": ["error", { "allow": ["**/*.css", "@testing-library/jest-dom/vitest"] }],

    "promise/always-return": "off",

    "unicorn/no-null": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-array-reduce": "off",
    "unicorn/no-await-expression-member": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/prefer-global-this": "off",
    "unicorn/switch-case-braces": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/no-array-callback-reference": "off",
    "unicorn/prefer-at": "off",
    "unicorn/prefer-code-point": "off",

    "no-ternary": "off",
    "no-nested-ternary": "off",
    "capitalized-comments": "off",
    "sort-keys": "off",
    "sort-imports": "off",
    "no-magic-numbers": "off",
    "promise/avoid-new": "off",
    "no-duplicate-imports": ["warn", { "includeExports": false, "allowSeparateTypeImports": true }],
    "id-length": ["warn", { "min": 1 }],
    "func-style": ["warn", "declaration", { "allowArrowFunctions": true }],
    "max-lines": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
    "max-lines-per-function": ["warn", { "max": 200, "skipBlankLines": true, "skipComments": true }],
    "max-statements": ["warn", { "max": 30 }],
    "max-params": ["warn", { "max": 5 }]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
      "rules": {
        "no-console": "off",
        "typescript/no-explicit-any": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/consistent-type-imports": "off",
        "import/first": "off",
        "require-await": "off",
        "max-lines": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
        "max-lines-per-function": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
        "max-statements": ["warn", { "max": 100 }]
      }
    }
  ],
  "settings": {
    "react": {
      "runtime": "automatic"
    }
  }
}
