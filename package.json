{
  "private": true,
  "scripts": {
    "prepare": "husky",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:lightpanda": "cd e2e && npx playwright test --project=lightpanda",
    "test:e2e:chromium": "cd e2e && npx playwright test --project=chromium"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^16.0.0",
    "oxlint": "^1.0.0",
    "oxfmt": "^0.22.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "oxlint",
      "oxfmt --write"
    ],
    "py_backend/**/*.py": [
      "py_backend/.venv/bin/ruff format",
      "py_backend/.venv/bin/ruff check --fix"
    ]
  }
}
