{
  "private": true,
  "scripts": {
    "prepare": "husky",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:lightpanda": "cd e2e && npx playwright test --project=lightpanda",
    "test:e2e:chromium": "cd e2e && npx playwright test --project=chromium"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^16.0.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "oxlint",
      "oxfmt --write"
    ],
    "backend/src/**/*.rs": [
      "bash -c 'source \"$HOME/.cargo/env\" && cd backend && cargo fmt -- --check'",
      "bash -c 'source \"$HOME/.cargo/env\" && cd backend && cargo clippy --all-targets -- -D warnings'"
    ]
  }
}
