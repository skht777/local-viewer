# コンテンツ親ディレクトリ (読み取り専用でコンテナの /mnt-host にマウント)
# この配下のサブディレクトリを manage_mounts.py でマウントポイントとして登録
DATA_DIR=/path/to/your/media

# Port exposed on host
HOST_PORT=8000

# Bind address: 127.0.0.1 (local only) or 0.0.0.0 (LAN accessible)
BIND_HOST=127.0.0.1

# Resource limits
MEM_LIMIT=2g
CPUS=2.0

# Search / Index
INDEX_DB_PATH=/tmp/viewer-disk-cache/index.db
DISK_CACHE_SIZE=2g
WATCH_MODE=auto
WATCH_POLL_INTERVAL=30
REBUILD_RATE_LIMIT_SECONDS=60
SEARCH_MAX_RESULTS=200
SEARCH_QUERY_TIMEOUT=5
