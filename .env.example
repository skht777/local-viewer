# コンテナ内のマウント親ディレクトリ
# (これはコンテナ内パスなので Windows でも /mnt-host のまま変更不要)
MOUNT_BASE_DIR=/mnt-host

# Windows: config/mounts.json の host_path は C:\Users\foo のように書けます。
#   start.ps1 / start.sh が起動時に実行環境に応じた形式へ自動変換します。

# ホスト側ポート
HOST_PORT=8000

# バインドアドレス: 127.0.0.1 (ローカルのみ) / 0.0.0.0 (LAN 公開)
BIND_HOST=127.0.0.1

# リソース制限
MEM_LIMIT=2g
CPUS=2.0
DISK_CACHE_SIZE=2g

# インデックススキャンの並列スレッド数 (init.sh が自動設定)
SCAN_WORKERS=8

# 動画サムネイル設定
# VIDEO_THUMB_SEEK_SECONDS=1
# VIDEO_THUMB_TIMEOUT=10

# tracing ログレベル (未設定時はバックエンド既定の info)
# browse / thumbnail.batch / scan の計測イベントは info で出る
# RUST_LOG=info

# node_id HMAC 署名・カーソル署名に使う秘密鍵（必須。未設定/空文字は起動時 panic）
# 生成例: openssl rand -hex 32
NODE_SECRET=
